  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "node --preserve-symlinks --preserve-symlinks-main ./scripts/run-vite.mjs --host 127.0.0.1 --configLoader native",
    "typecheck": "node ./node_modules/typescript/bin/tsc -b",
    "check": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build --configLoader native",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build --configLoader native",
    "preview": "node --preserve-symlinks --preserve-symlinks-main ./scripts/run-vite.mjs preview --host 127.0.0.1 --configLoader native"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.8.0"
  }
}
